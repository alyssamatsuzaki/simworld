# SimWorld — example environment variables
#
# SimWorld runs fully offline with zero secrets by default: the whole `make smoke`
# pipeline needs NONE of these. Copy this file to `.env` and edit only if you opt into
# a networked backend (Weights & Biases, a Ray cluster) or want to relocate outputs.
#
#   cp .env.example .env
#
# `.env` is git-ignored. Never commit real credentials.

# ─── Artifact location ────────────────────────────────────────────────────────
# Where the pipeline writes worlds, posteriors, cubes, and figures.
# Read by configs/config.yaml (paths.root). Default: ./artifacts
SIMWORLD_ARTIFACT_ROOT=artifacts

# ─── Experiment tracking ──────────────────────────────────────────────────────
# The default tracking backend is MLflow with a local SQLite file
# (configs/tracking/mlflow.yaml) — no credentials, no network. Nothing to set here.
#
# Optional: override the MLflow store (e.g. a shared tracking server).
# MLFLOW_TRACKING_URI=sqlite:///experiments/mlflow.db
#
# Optional: to use the Weights & Biases backend instead (tracking=wandb), set a key.
# Without a key SimWorld forces WANDB_MODE=offline and logs locally — it never blocks.
# WANDB_API_KEY=
# WANDB_MODE=offline

# ─── Distributed compute (optional) ───────────────────────────────────────────
# Address of an existing Ray cluster for the scenario ensemble (compute=ray_cluster).
# Leave unset to run Ray locally. Read by configs/compute/ray_cluster.yaml.
# RAY_ADDRESS=

# ─── Runtime / reproducibility ────────────────────────────────────────────────
# `make` exports these for you; set them only if you invoke scripts/*.py directly.
JAX_PLATFORMS=cpu                 # every JAX calibration stage runs CPU-only for portability
MPLBACKEND=Agg                    # headless Matplotlib (no display required)
XLA_PYTHON_CLIENT_PREALLOCATE=false
PYTHONHASHSEED=0                  # deterministic hashing — part of the reproducibility contract
PYTHONUTF8=1
